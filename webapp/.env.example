# ─── Supabase ────────────────────────────────────────────────────────────────
# Obtenés estos valores en: https://supabase.com/dashboard → Settings → API

# URL pública del proyecto Supabase (seguro exponer al cliente)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co

# Clave anon (seguro exponer al cliente — RLS protege los datos)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — NUNCA exponer al cliente, solo server-side
# Úsala únicamente en API routes y Server Components que lo requieran
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Site ────────────────────────────────────────────────────────────────────
# URL pública del sitio (sin trailing slash)
# En desarrollo: http://localhost:3000
# En producción: https://tudominio.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
